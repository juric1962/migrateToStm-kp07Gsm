//  340 
//  341 
//  342 //void opros_ts(unsigned char num, unsigned char port, unsigned char pin, struct struct_ts *ts, unsigned int *tii)

        RSEG CODE:CODE:NOROOT(1)
//  343 void opros_ts(unsigned char num, unsigned char port, unsigned char pin, struct struct_ts *ts)
opros_ts:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function opros_ts
//  344 
//  345 {
        CALL	?PROLOGUE4_L09
        CFI R27 Frame(CFA_Y, -1)
        CFI R26 Frame(CFA_Y, -2)
        CFI R25 Frame(CFA_Y, -3)
        CFI R24 Frame(CFA_Y, -4)
        CFI CFA_Y Y+4
        MOV	R22, R16
        MOVW	R31:R30, R21:R20
//  346   if(port & pin)ts->tek_pin=0;else ts->tek_pin=1;
        AND	R18, R17
        LD	R16, Z
        BREQ	??opros_ts_0
        ANDI	R16, 0xFE
        RJMP	??opros_ts_1
??opros_ts_0:
        ORI	R16, 0x01
??opros_ts_1:
        ST	Z, R16
//  347    if(ts->fl_ch_tc==1)
        LD	R16, Z
        SBRS	R16, 2
        RJMP	??opros_ts_2
//  348      {
//  349        ts->count_tc--;
        LDD	R16, Z+1
        DEC	R16
        STD	Z+1, R16
//  350        if(ts->count_tc==0)
        LDD	R16, Z+1
        TST	R16
        BREQ	$+2+2
        RJMP	??opros_ts_3
//  351        {
//  352          ts->fl_ch_tc=0;
        LD	R16, Z
        ANDI	R16, 0xFB
        ST	Z, R16
//  353        //  ts->real_tc=0x01 & (~ts->tek_pin);
//  354         // *tii++;
//  355        //  modbus_mem1[num]=*tii;
//  356          modbus_mem1[AD_TII1+num]++;
        MOV	R18, R22
        LDI	R19, 0
        LDI	R24, LOW(modbus_mem1)
        LDI	R25, (modbus_mem1) >> 8
        MOVW	R17:R16, R19:R18
        LSL	R16
        ROL	R17
        MOVW	R27:R26, R25:R24
        ADD	R26, R16
        ADC	R27, R17
        LD	R16, X+
        LD	R17, X
        SUBI	R16, 255
        SBCI	R17, 255
        ST	X, R17
        ST	-X, R16
//  357          arr_tii_32[num]++;
        LSL	R18
        ROL	R19
        LSL	R18
        ROL	R19
        MOVW	R27:R26, R19:R18
        SUBI	R26, LOW((-(arr_tii_32) & 0xFFFF))
        SBCI	R27, (-(arr_tii_32) & 0xFFFF) >> 8
        LD	R16, X+
        LD	R17, X+
        LD	R18, X+
        LD	R19, X
        SUBI	R16, 255
        SBCI	R17, 255
        SBCI	R18, 255
        SBCI	R19, 255
        ST	X, R19
        ST	-X, R18
        ST	-X, R17
        ST	-X, R16
//  358          modbus_mem1[AD_TS]=(modbus_mem1[AD_TS] & (~(0x01<<num))) | (ts->tek_pin <<num);
        MOVW	R27:R26, R25:R24
        ADIW	R27:R26, 48
        LD	R18, X+
        LD	R19, X
        LDI	R16, 1
        LDI	R17, 0
        MOV	R20, R22
        CALL	?S_SHL_L02
        MOVW	R1:R0, R17:R16
        COM	R0
        COM	R1
        AND	R0, R18
        AND	R1, R19
        LD	R16, Z
        ANDI	R16, 0x01
        LDI	R17, 0
        MOV	R20, R22
        CALL	?S_SHL_L02
        OR	R16, R0
        OR	R17, R1
        MOVW	R27:R26, R25:R24
        ADIW	R27:R26, 48
        ST	X+, R16
        ST	X, R17
        RJMP	??opros_ts_3
//  359        }
//  360      } 
//  361      else
//  362      {
//  363        if(ts->tek_pin!=ts->old_pin)
??opros_ts_2:
        LD	R16, Z
        ANDI	R16, 0x01
        LD	R17, Z
        BST	R17, 1
        LDI	R17, 0
        BLD	R17, 0
        CP	R16, R17
        BREQ	??opros_ts_3
//  364        {
//  365        ts->fl_ch_tc=1;
        LD	R16, Z
        ORI	R16, 0x04
        ST	Z, R16
//  366        ts->count_tc=30;
        LDI	R16, 30
        STD	Z+1, R16
//  367        }
//  368      }
//  369     ts->old_pin=ts->tek_pin;
??opros_ts_3:
        LD	R16, Z
        ANDI	R16, 0x01
        BST	R16, 0
        LD	R16, Z
        BLD	R16, 1
        ST	Z, R16
//  370 }
        LDI	R30, 4
        JMP	?EPILOGUE_B4_L09
        CFI EndBlock cfiBlock0
//  371 
//  372 
//  373 
//  374 

        RSEG CODE:CODE:NOROOT(1)
//  375 void sending_ppp_proverka(void)
sending_ppp_proverka:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function sending_ppp_proverka
//  376 {   
        MOVW	R19:R18, R27:R26
//  377    if(count_tx_ppp>=20)
        LDI	R26, LOW(count_tx_ppp)
        LDI	R27, (count_tx_ppp) >> 8
        LD	R30, X+
        LD	R31, X
        SBIW	R31:R30, 20
        BRCS	??sending_ppp_proverka_0
//  378    {
//  379     // UCSR0B=UCSR0B & ~TXEN;!!!!
//  380     // UCSR0B=UCSR0B & ~TXCIE; !!!!
//  381      S2_OFF;
        CBI	0x08, 0x00
        CBI	0x08, 0x01
//  382      return;
        RJMP	??sending_ppp_proverka_1
//  383    }
//  384    
//  385    UDR0=buf_tx_232[count_tx_ppp]; if(Regim==RG_DEBAG) UDR3=buf_tx_232[count_tx_ppp];
??sending_ppp_proverka_0:
        LDI	R30, LOW(count_tx_ppp)
        LDI	R31, (count_tx_ppp) >> 8
        LD	R16, Z
        LDD	R17, Z+1
        MOVW	R31:R30, R17:R16
        SUBI	R30, LOW((-(buf_tx_232) & 0xFFFF))
        SBCI	R31, (-(buf_tx_232) & 0xFFFF) >> 8
        LD	R17, Z
        STS	198, R17
        LDS	R16, Regim
        CPI	R16, 1
        BRNE	??sending_ppp_proverka_2
        STS	310, R17
//  386    count_tx_ppp++;
??sending_ppp_proverka_2:
        LDI	R30, LOW(count_tx_ppp)
        LDI	R31, (count_tx_ppp) >> 8
        LD	R16, Z
        LDD	R17, Z+1
        SUBI	R16, 255
        SBCI	R17, 255
        ST	Z, R16
        STD	Z+1, R17
//  387 }
??sending_ppp_proverka_1:
        MOVW	R27:R26, R19:R18
        RET
        CFI EndBlock cfiBlock1
//  388 
//  389 
//  390 

        RSEG CODE:CODE:NOROOT(1)
//  391   void sending_ppp_pac(void)
sending_ppp_pac:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function sending_ppp_pac
//  392 {   
//  393   cnt_supervosor=0;
        LDI	R16, 0
        LDI	R30, LOW(cnt_supervosor)
        LDI	R31, (cnt_supervosor) >> 8
        ST	Z, R16
        STD	Z+1, R16
//  394   
//  395  if(count_tx_ppp>=(vol_tx_ppp-1))
        LDI	R30, LOW(vol_tx_ppp)
        LDI	R31, (vol_tx_ppp) >> 8
        LD	R16, Z
        LDD	R17, Z+1
        SUBI	R16, 1
        SBCI	R17, 0
        LDI	R30, LOW(count_tx_ppp)
        LDI	R31, (count_tx_ppp) >> 8
        LD	R18, Z
        LDD	R19, Z+1
        CP	R18, R16
        CPC	R19, R17
        BRCS	??sending_ppp_pac_0
//  396      { 
//  397   
//  398      if (fl_lcp.act_lcp_end==0) fl_lcp.act_lcp_end=1;
        LDI	R30, LOW(fl_lcp)
        LDI	R31, (fl_lcp) >> 8
        LD	R16, Z
        SBRC	R16, 0
        RJMP	??sending_ppp_pac_1
        LD	R16, Z
        ORI	R16, 0x01
        ST	Z, R16
//  399      if (fl_pap.act_pap_end==0) fl_pap.act_pap_end=1;    
??sending_ppp_pac_1:
        LDI	R30, LOW(fl_pap)
        LDI	R31, (fl_pap) >> 8
        LD	R16, Z
        SBRC	R16, 0
        RJMP	??sending_ppp_pac_2
        LD	R16, Z
        ORI	R16, 0x01
        ST	Z, R16
//  400      if (fl_ipcp.act_ipcp_end==0) fl_ipcp.act_ipcp_end=1;  
??sending_ppp_pac_2:
        LDI	R30, LOW(fl_ipcp)
        LDI	R31, (fl_ipcp) >> 8
        LD	R16, Z
        SBRC	R16, 0
        RJMP	??sending_ppp_pac_3
        LD	R16, Z
        ORI	R16, 0x01
        ST	Z, R16
//  401      if (fl_ip.act_ip_end==0) fl_ip.act_ip_end=1; 
??sending_ppp_pac_3:
        LDI	R30, LOW(fl_ip)
        LDI	R31, (fl_ip) >> 8
        LD	R16, Z
        SBRC	R16, 0
        RJMP	??sending_ppp_pac_4
        LD	R16, Z
        ORI	R16, 0x01
        ST	Z, R16
//  402      fl_reg3.add_byte=0;   
??sending_ppp_pac_4:
        LDI	R30, LOW(fl_reg3)
        LDI	R31, (fl_reg3) >> 8
        LD	R16, Z
        ANDI	R16, 0xFE
        ST	Z, R16
//  403    //  UCSR0B=UCSR0B & ~TXEN;!!!!!!!
//  404    //  UCSR0B=UCSR0B & ~TXCIE; !!!!
//  405      S2_OFF;
        CBI	0x08, 0x00
        CBI	0x08, 0x01
//  406      return;
        RET
//  407      }   
//  408       
