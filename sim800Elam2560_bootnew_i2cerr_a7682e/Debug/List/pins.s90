//   61 {
//   62   //Конфигурирование ног порта №0 RS232-1
//   63   PIN_OUT_PORT0;
        RCALL	?Subroutine3
//   64   PIN_IN_PORT0;
//   65   SET_DTR0;
//   66   SET_RTS0;
//   67   
//   68   UCSR0B=UCSR0B | RXEN;
??CrossCallReturnLabel_0:
        RCALL	?Subroutine1
//   69   UCSR0B=UCSR0B | TXEN; 
//   70   UCSR0B=UCSR0B | RXCIE;
//   71   UCSR0A=UCSR0A | TXC;
??CrossCallReturnLabel_113:
        RCALL	?Subroutine13
??CrossCallReturnLabel_12:
        ORI	R16, 0x40
        CFI EndBlock cfiBlock0
        REQUIRE ?Subroutine52
