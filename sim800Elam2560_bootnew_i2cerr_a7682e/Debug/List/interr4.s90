        RSEG FARCODE:CODE:NOROOT(1)
//  367 void send_485_1(void)
send_485_1:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function send_485_1
//  368 {
        MOVW	R19:R18, R27:R26
//  369 UCSR3B=UCSR3B & ~(RXCIE | RXEN);   
        LDS	R16, 305
        ANDI	R16, 0x6F
        STS	305, R16
//  370 UCSR3B=UCSR3B | TXCIE;  // enable transmit 485_1
        LDS	R16, 305
        ORI	R16, 0x40
        STS	305, R16
//  371 UDR3=*Rs485_1.p_data485++;
        LDI	R30, LOW(Rs485_1)
        LDI	R31, (Rs485_1) >> 8
        LDD	R26, Z+16
        LDD	R27, Z+17
        LD	R16, X
        STS	310, R16
        LDD	R16, Z+16
        LDD	R17, Z+17
        RCALL	?Subroutine1
??CrossCallReturnLabel_2:
        STD	Z+16, R16
        STD	Z+17, R17
//  372 Rs485_1.cnt_bt_rx_tx--; 
        RCALL	?Subroutine2
??CrossCallReturnLabel_8:
        ST	Z, R16
        STD	Z+1, R17
//  373 }
        RJMP	?Subroutine82
        CFI EndBlock cfiBlock0
//  374 

        RSEG FARCODE:CODE:NOROOT(1)
//  375 void send_485_2(void)
send_485_2:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function send_485_2
//  376 {
        MOVW	R19:R18, R27:R26
//  377 UCSR1B=UCSR1B & ~(RXCIE | RXEN);   
        LDS	R16, 201
        ANDI	R16, 0x6F
        STS	201, R16
//  378 UCSR1B=UCSR1B | TXCIE;  // enable transmit 485_2
        LDS	R16, 201
        ORI	R16, 0x40
        STS	201, R16
//  379 UDR1=*Rs485_2.p_data485++;
        LDI	R30, LOW(Rs485_1)
        LDI	R31, (Rs485_1) >> 8
        LDD	R26, Z+34
        LDD	R27, Z+35
        LD	R16, X
        STS	206, R16
        LDD	R16, Z+34
        LDD	R17, Z+35
        RCALL	?Subroutine1
??CrossCallReturnLabel_3:
        STD	Z+34, R16
        STD	Z+35, R17
//  380 Rs485_2.cnt_bt_rx_tx--; 
        LDD	R16, Z+18
        LDD	R17, Z+19
        SUBI	R16, 1
        SBCI	R17, 0
        STD	Z+18, R16
        STD	Z+19, R17
//  381 }
        RJMP	?Subroutine82
        CFI EndBlock cfiBlock1
//  382 

        RSEG FARCODE:CODE:NOROOT(1)
//  383 void send_232_2(void)
send_232_2:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function send_232_2
//  384 {
        MOVW	R19:R18, R27:R26
//  385 UCSR2B=UCSR2B & ~(RXCIE | RXEN);   
        LDS	R16, 209
        ANDI	R16, 0x6F
        STS	209, R16
//  386 UCSR2B=UCSR2B | TXCIE;  // enable transmit 485_2
        LDS	R16, 209
        ORI	R16, 0x40
        STS	209, R16
//  387 UDR2=*Rs232_2.p_data485++;
        LDI	R30, LOW(Rs485_1)
        LDI	R31, (Rs485_1) >> 8
        LDD	R26, Z+52
        LDD	R27, Z+53
        LD	R16, X
        STS	214, R16
        LDD	R16, Z+52
        LDD	R17, Z+53
        RCALL	?Subroutine1
??CrossCallReturnLabel_4:
        STD	Z+52, R16
        STD	Z+53, R17
//  388 Rs232_2.cnt_bt_rx_tx--; 
        LDD	R16, Z+36
        LDD	R17, Z+37
        SUBI	R16, 1
        SBCI	R17, 0
        STD	Z+36, R16
        STD	Z+37, R17
        CFI EndBlock cfiBlock2
//  389 }
