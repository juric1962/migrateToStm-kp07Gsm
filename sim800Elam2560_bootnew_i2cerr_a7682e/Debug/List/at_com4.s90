        LDI	R31, HIGH((At_com + 63))
        LD	R16, Z
        LDD	R17, Z+1
        LDI	R30, LOW((At_com + 61))
        LDI	R31, HIGH((At_com + 61))
        ST	Z, R16
        STD	Z+1, R17
//   93      UCSR0B=UCSR0B | RXEN;
