// 2018                             }
// 2019 
// 2020            /*  Add left-over byte, if any */
// 2021        if( count > 0 )   
// 2022                {
// 2023                temp1.bytes[0]=0;
// 2024                temp1.bytes[1]=*p; 
// 2025                temp2.long_word=temp2.long_word+temp1.word; 
