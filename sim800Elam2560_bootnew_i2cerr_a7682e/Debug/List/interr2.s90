//  280 void sending_ppp_proverka(void)
sending_ppp_proverka:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function sending_ppp_proverka
//  281 {   
        MOVW	R19:R18, R27:R26
//  282    if(count_tx_ppp>=20)
        LDI	R26, LOW(count_tx_ppp)
        LDI	R27, (count_tx_ppp) >> 8
        LD	R30, X+
        LD	R31, X
        SBIW	R31:R30, 20
        BRCS	??sending_ppp_proverka_0
//  283    {
//  284     // UCSR0B=UCSR0B & ~TXEN;!!!!
//  285     // UCSR0B=UCSR0B & ~TXCIE; !!!!
//  286      S2_OFF;
        CBI	0x08, 0x00
        CBI	0x08, 0x01
//  287      return;
        RJMP	??sending_ppp_proverka_1
//  288    }
//  289    
//  290    UDR0=buf_tx_232[count_tx_ppp]; if(Regim==RG_DEBAG) UDR3=buf_tx_232[count_tx_ppp];
??sending_ppp_proverka_0:
        LDI	R30, LOW(count_tx_ppp)
        LDI	R31, (count_tx_ppp) >> 8
        LD	R16, Z
        LDD	R17, Z+1
        MOVW	R31:R30, R17:R16
        SUBI	R30, LOW((-(buf_tx_232) & 0xFFFF))
        SBCI	R31, (-(buf_tx_232) & 0xFFFF) >> 8
        LD	R17, Z
        STS	198, R17
        LDS	R16, Regim
        CPI	R16, 1
        BRNE	??sending_ppp_proverka_2
        STS	310, R17
//  291    count_tx_ppp++;
??sending_ppp_proverka_2:
        LDI	R30, LOW(count_tx_ppp)
        LDI	R31, (count_tx_ppp) >> 8
        LD	R16, Z
        LDD	R17, Z+1
        SUBI	R16, 255
        SBCI	R17, 255
        ST	Z, R16
        STD	Z+1, R17
//  292 }
??sending_ppp_proverka_1:
        MOVW	R27:R26, R19:R18
        RET
        CFI EndBlock cfiBlock0
