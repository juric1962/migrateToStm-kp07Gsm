//   55 void tx_rs485_1(void)
tx_rs485_1:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function tx_rs485_1
//   56 {
        CALL	?PROLOGUE4_L09
        CFI R27 Frame(CFA_Y, -1)
        CFI R26 Frame(CFA_Y, -2)
        CFI R25 Frame(CFA_Y, -3)
        CFI R24 Frame(CFA_Y, -4)
        CFI CFA_Y Y+4
//   57   unsigned int i;
//   58  
//   59     Rs485_1.cnt_bt_rx_tx=10;
        LDI	R30, LOW(Rs485_1)
        LDI	R31, (Rs485_1) >> 8
        LDI	R16, 10
        LDI	R17, 0
        ST	Z, R16
        STD	Z+1, R17
//   60     for(i=0;i<Rs485_1.cnt_bt_rx_tx;i++)Rs485_1_buf_rx_tx[i]=i;
        LDI	R24, 0
        LDI	R25, 0
        RJMP	??tx_rs485_1_0
??tx_rs485_1_1:
        MOV	R16, R24
        MOVW	R27:R26, R25:R24
        SUBI	R26, LOW((-(Rs485_1_buf_rx_tx) & 0xFFFF))
        SBCI	R27, (-(Rs485_1_buf_rx_tx) & 0xFFFF) >> 8
        ST	X, R16
        ADIW	R25:R24, 1
??tx_rs485_1_0:
        LD	R16, Z
        LDD	R17, Z+1
        CP	R24, R16
        CPC	R25, R17
        BRCS	??tx_rs485_1_1
//   61     Rs485_1.p_data485=&Rs485_1_buf_rx_tx[0];
        LDI	R16, LOW(Rs485_1_buf_rx_tx)
        LDI	R17, (Rs485_1_buf_rx_tx) >> 8
        STD	Z+16, R16
        STD	Z+17, R17
//   62     //здесь должна быть функция настройки порта по контексту.
//   63  
//   64     UBRR3H=R2400_H;
        LDI	R16, 1
        STS	309, R16
//   65     UBRR3L=R2400_L;
        LDI	R16, 159
        STS	308, R16
//   66     
//   67     UCSR3B=UCSR3B & ~(RXCIE | RXEN);      
        LDS	R16, 305
        ANDI	R16, 0x6F
        STS	305, R16
//   68     
//   69     Rs485_1.cnt_tm_tx_out=0;
        LDI	R16, 0
        LDI	R17, 0
        STD	Z+2, R16
        STD	Z+3, R16
//   70     Rs485_1.vol_tm_tx_out=15; 
        LDI	R16, 15
        STD	Z+6, R16
        STD	Z+7, R17
//   71     
//   72     Rs485_1.cnt_tm_pre_tx=20;// 20 миллисекунд
        LDI	R16, 20
        STD	Z+4, R16
        STD	Z+5, R17
//   73     
//   74     Rs485_1.cnt_tm_rx_out=0;
        STD	Z+8, R17
        STD	Z+9, R17
//   75     Rs485_1.vol_tm_rx_out=10;// 5 миллисекунд
        LDI	R16, 10
        STD	Z+10, R16
        STD	Z+11, R17
//   76     
//   77     
//   78     Rs485_1.cnt_tm_out=0;
        STD	Z+12, R17
        STD	Z+13, R17
//   79     Rs485_1.vol_tm_out=600; // 600 миллисекунд
        LDI	R16, 88
        LDI	R17, 2
        STD	Z+14, R16
        STD	Z+15, R17
//   80   
//   81     SET_RTS1;  //rts на передачу
        LDS	R16, 261
        ORI	R16, 0x04
        STS	261, R16
//   82      
//   83 }
        LDI	R30, 4
        JMP	?EPILOGUE_B4_L09
        CFI EndBlock cfiBlock0
