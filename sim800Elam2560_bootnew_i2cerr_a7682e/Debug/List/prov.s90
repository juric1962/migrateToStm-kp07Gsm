//  146 void tx_rs232_time(void)
tx_rs232_time:
        CFI Block cfiBlock3 Using cfiCommon0
        CFI Function tx_rs232_time
//  147 {
//  148    // if (proverka!=1)return;
//  149    // proverka=0;
//  150     proverka++;
        FUNCALL tx_rs232_time, burst
        LOCFRAME RSTACK, 2, STACK
        LDI	R30, LOW(proverka)
        LDI	R31, (proverka) >> 8
        LD	R16, Z
        INC	R16
        ST	Z, R16
//  151   
//  152     UCSR2B=UCSR2B & ~(RXCIE | RXEN); 
        LDS	R16, 209
        ANDI	R16, 0x6F
        STS	209, R16
//  153     
//  154  //   burst_ds_r();
//  155     burst();
        CALL	burst
//  156     Rs232_2.cnt_bt_rx_tx=13;
        LDI	R30, LOW(Rs232_2)
        LDI	R31, (Rs232_2) >> 8
        LDI	R16, 13
        LDI	R17, 0
        ST	Z, R16
        STD	Z+1, R17
